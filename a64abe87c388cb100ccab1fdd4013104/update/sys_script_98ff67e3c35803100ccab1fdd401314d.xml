        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {

	// Add your code here
	 // Safety: only act when status has a value
    if (!current.reservation_status) {
        return;
    }

    // Map reservation status → task state
    if (current.reservation_status == 'checked_in') {
        current.state = 1; // Open
    } 
    else if (current.reservation_status == 'checked_out') {
        current.state = 3; // Closed Complete
    } 
    else if (current.reservation_status == 'no_show' || 
             current.reservation_status == 'cancelled') {
        current.state = 7; // Closed Skipped
    }

})(current, previous);]]></script>
