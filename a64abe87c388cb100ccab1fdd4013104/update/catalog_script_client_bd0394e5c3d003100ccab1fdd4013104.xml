        <name>Start/End Date Validation</name>
        <order/>
        <published_ref/>
        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading) {
    if (isLoading || newValue == '') {
        return;
    }
    var startDate = g_form.getValue('start_date_time');
    var endDate = g_form.getValue('end_date_time');

    if (startDate != '' && endDate < startDate) {
        g_form.clearValue('end_date_time');
        g_form.showFieldMsg('end_date_time', 'End date/time should not be before the Start date/time', 'error', false);

    } else if (startDate == '') {

        g_form.clearValue('end_date_time');
        g_form.showFieldMsg('end_date_time', 'Enter start date/time before proceeding to End date/time', 'error', false);

    }

    return true;

}]]></script>
